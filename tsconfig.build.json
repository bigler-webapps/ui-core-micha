{
  "compilerOptions": {
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2017",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false
  },
  "include": ["src"]
}
